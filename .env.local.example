# Copy to .env.local and fill in values.
# For local dev without Docker, start Redis with: docker run -p 6379:6379 redis:7-alpine

# Redis connection (defaults to localhost:6379 if unset)
REDIS_URL=redis://localhost:6379

# Event room ID — everyone in the same room must use the same value
NEXT_PUBLIC_EVENT_ID=HACK-AI-2026

# Presence TTL in seconds (how long a user stays "in the room" after joining)
PRESENCE_TTL=1800
