{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/onboarding/layout,_N_T_/onboarding/preview/layout,_N_T_/onboarding/preview/page,_N_T_/onboarding/preview"
  },
  "segmentPaths": [
