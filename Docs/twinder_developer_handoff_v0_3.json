{
  "project": "Twinder",
  "artifact_version": "0.3",
  "date": "2026-06-06",
  "artifact_type": "MVP UX + developer handoff",
  "mvp": {
    "launch_context": "hackathon event",
    "onboarding_timing": [
      "before event",
      "at event via QR/link"
    ],
    "mode": "fluid networking + dating; no hard mode switching required for MVP",
    "photos": {
      "mvp": "no photos",
      "v3": "photos may be introduced later"
    },
    "matching": {
      "trigger": "as users join",
      "process": [
        "generate twin profile",
        "generate matching vector",
        "compare with attendee pool",
        "run twin-to-twin conversation for promising candidates",
        "score match",
        "surface matches"
      ],
      "numeric_scores_visible": true,
      "hide_low_scores_by_default_below": 50
    },
    "twin_tone": {
      "persona": "wingman",
      "theatricality_default": "lightly theatrical to character-dialogue",
      "can_be_flirty": true,
      "explicit_sexual_content_first_contact": false
    },
    "identity_reveal": {
      "before_intro_allowed": [
        "first name if public",
        "public role/company/school",
        "public project/interests",
        "intent chips",
        "resonance score",
        "suggested conversation topic",
        "twin-generated summary"
      ],
      "before_intro_forbidden": [
        "photos",
        "contact info",
        "private YAML/profile fields",
        "sensitive details"
      ]
    }
  },
  "primary_dashboard_sections": [
    "Twin status",
    "Live room activity",
    "Best matches",
    "Twin talks",
    "Intros",
    "Tune my twin"
  ],
  "screens": [
    "Event Entry / QR Landing",
    "Onboarding",
    "Twin Generated",
    "Dashboard / Discover",
    "Twin Talk Detail",
    "Intro Request",
    "Mutual Intro"
  ],
  "components": {
