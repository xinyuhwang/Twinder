      "props": [
        "score",
        "label",
        "confidence"
      ],
      "notes": "Always accompany with explanation"
    },
    "MatchCard": {
      "props": [
        "publicName",
        "publicRoleOrProject",
        "resonanceScore",
        "resonanceLabel",
        "sharedSignals",
        "suggestedTopic",
        "ctaState"
