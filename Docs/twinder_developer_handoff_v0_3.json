    "TwinTalkCard": {
      "props": [
        "theirTwinLine",
        "yourTwinLine",
        "summary",
        "tone"
      ]
    },
    "IntroRequestCard": {
      "props": [
        "targetPublicName",
        "reason",
        "suggestedMessage",
        "status"
      ]
    },
